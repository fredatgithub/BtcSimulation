<Window x:Class="BtcSimulation.ChartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Courbe BTC (EUR)"
        Width="520" Height="450"
        WindowStartupLocation="Manual"
        ResizeMode="CanResizeWithGrip"
        SizeChanged="ChartWindow_OnSizeChanged">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="BTC (EUR) - historique" FontSize="16" FontWeight="SemiBold"/>

        <Border Grid.Row="1" Margin="0,10,0,10" Background="#FFFFFF" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="8">
            <Grid>
                <Canvas x:Name="PlotCanvas" Margin="10" Background="Transparent">
                    <Polyline x:Name="PriceLine" Stroke="#1E88E5" StrokeThickness="2" />
                </Canvas>
                <TextBlock x:Name="EmptyText"
                           Text="En attente de données…"
                           Foreground="#666666"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <DockPanel Grid.Row="2" LastChildFill="False">
            <TextBlock x:Name="RangeText" Foreground="#666666" DockPanel.Dock="Left"/>
            <TextBlock x:Name="LastPointText" Foreground="#666666" DockPanel.Dock="Right"/>
        </DockPanel>
    </Grid>
</Window>
