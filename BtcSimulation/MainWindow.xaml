<Window x:Class="BtcSimulation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BtcSimulation"
        mc:Ignorable="d"
        Title="Simulation BTC" Height="450" Width="800"
        Loaded="MainWindow_OnLoaded"
        Closing="MainWindow_OnClosing">
    <Grid>
        <Border Margin="16" Padding="16" CornerRadius="10" BorderThickness="1" BorderBrush="#DDDDDD" Background="#FAFAFA">
            <StackPanel>
                <TextBlock Text="Taux BTC" FontSize="20" FontWeight="SemiBold"/>

                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="BTC (EUR) :" FontSize="16" />
                    <TextBlock x:Name="BtcPriceText"
                               Text="—"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="8,0,0,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <TextBlock Text="BTC (USD) :" FontSize="16" />
                    <TextBlock x:Name="BtcPriceUsdText"
                               Text="—"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="8,0,0,0"/>
                </StackPanel>

                <TextBlock x:Name="LastUpdatedText"
                           Text="Dernière mise à jour : —"
                           Margin="0,8,0,0"
                           FontSize="16"
                           Foreground="#666666"/>

                <TextBlock x:Name="StatusText"
                           Text=""
                           Margin="0,6,0,0"
                           Foreground="#A00000"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
